# ============================================
# Next.js Frontend Environment Variables
# ⚠️ .env.local 파일은 Git에 커밋하지 마세요
# ============================================

# --------------------------------------------
# API Base URL — 환경에 맞게 ONE block 주석 해제
# --------------------------------------------

# local: 모두 localhost (직접 연결)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/mgmt/v1
NEXT_PUBLIC_API_BASE_URL_SVC=http://localhost:4000/api/svc/v1
NEXT_PUBLIC_API_BASE_URL_PUBLIC=http://localhost:4000/api/public/v1
SERVER_API_URL=http://localhost:4000

# staging (Vercel Preview): 상대경로 → Next.js rewrite → Render 프록시
# NEXT_PUBLIC_API_BASE_URL=/api/mgmt/v1
# NEXT_PUBLIC_API_BASE_URL_SVC=/api/svc/v1
# NEXT_PUBLIC_API_BASE_URL_PUBLIC=/api/public/v1
# SERVER_API_URL=https://ssambee-be.onrender.com

# production: EC2 직접 연결 (same-site, cross-subdomain 쿠키)
# NEXT_PUBLIC_API_BASE_URL=https://api.ssambee.com/api/mgmt/v1
# NEXT_PUBLIC_API_BASE_URL_SVC=https://api.ssambee.com/api/svc/v1
# NEXT_PUBLIC_API_BASE_URL_PUBLIC=https://api.ssambee.com/api/public/v1
# SERVER_API_URL=https://api.ssambee.com

# --------------------------------------------
# App
# --------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_APP_NAME=EduOps
NEXT_PUBLIC_ENABLE_MOCK_API=false

# --------------------------------------------
# Toss Payments
# --------------------------------------------
NEXT_PUBLIC_TOSS_PAYMENTS_CLIENT_KEY=YOUR_TOSS_PAYMENTS_CLIENT_KEY

# 무통장 입금 계좌
NEXT_PUBLIC_BANK_NAME=은행명
NEXT_PUBLIC_ACCOUNT_NUMBER=계좌번호
NEXT_PUBLIC_COMPANY_NAME=예금주명

# --------------------------------------------
# Sentry
# ⚠️ 운영환경에서는 반드시 false
# --------------------------------------------
NEXT_PUBLIC_SENTRY_SEND_PII=false
SENTRY_SEND_PII=false
NEXT_PUBLIC_GA_ID=G-XXXXXXX
